    "cors": "^2",
    "express": "^5",
    "jose": "^6.0.10",
    "pino": "^9",
    "pino-http": "^10",
    "sql.js": "^1.13.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.5.2",
    "esbuild": "^0.25.8",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0",
    "vitest": "^3.2.4"
  }
